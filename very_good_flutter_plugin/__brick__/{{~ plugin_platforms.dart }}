flutter:
  plugin:
    platforms:{{#android}}
      android:
        default_package: {{project_name.snakeCase()}}_android{{/android}}{{#supports_ios}}
      ios:
        default_package: {{project_name.snakeCase()}}_{{#darwin}}darwin{{/darwin}}{{^darwin}}ios{{/darwin}}{{/supports_ios}}{{#linux}}
      linux:
        default_package: {{project_name.snakeCase()}}_linux{{/linux}}{{#supports_macos}}
      macos:
        default_package: {{project_name.snakeCase()}}_{{#darwin}}darwin{{/darwin}}{{^darwin}}macos{{/darwin}}{{/supports_macos}}{{#web}}
      web:
        default_package: {{project_name.snakeCase()}}_web{{/web}}{{#windows}}
      windows:
        default_package: {{project_name.snakeCase()}}_windows{{/windows}}