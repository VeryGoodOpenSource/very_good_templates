  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch {{flavor_dev}}",
      "request": "launch",
      "type": "dart",
      "program": "lib/main_{{flavor_dev}}.dart",
      "args": [
        "--flavor",
        "{{flavor_dev}}",
        "--target",
        "lib/main_{{flavor_dev}}.dart"
      ]
    },
    {
      "name": "Launch {{flavor_staging}}",
      "request": "launch",
      "type": "dart",
      "program": "lib/main_{{flavor_staging}}.dart",
      "args": [
        "--flavor",
        "{{flavor_staging}}",
        "--target",
        "lib/main_{{flavor_staging}}.dart"
      ]
    },
    {
      "name": "Launch {{flavor_prod}}",
      "request": "launch",
      "type": "dart",
      "program": "lib/main_{{flavor_prod}}.dart",
      "args": [
        "--flavor",
        "{{flavor_prod}}",
        "--target",
        "lib/main_{{flavor_prod}}.dart"
      ]
    }
  ]
}
